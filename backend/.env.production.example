# =============================================
# 운영 환경 변수 템플릿 (Railway에 직접 입력)
# =============================================
# 이 파일은 참고용 템플릿입니다.
# 실제 값은 Railway 대시보드 > Variables에서 설정하세요.

# 서버 설정
PORT=5000
NODE_ENV=production

# 데이터베이스 (MongoDB Atlas)
# Atlas 클러스터 생성 후 연결 문자열 복사
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/workreview?retryWrites=true&w=majority

# JWT (openssl rand -base64 64 로 생성한 랜덤값 사용)
JWT_SECRET=<강력한_랜덤_시크릿_최소_64자>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<강력한_랜덤_시크릿_JWT_SECRET과_다른값>
JWT_REFRESH_EXPIRES_IN=7d

# 프론트엔드 URL (Vercel 배포 후 주소 입력)
FRONTEND_URL=https://your-app.vercel.app

# 이메일 (실제 SMTP 서버 - Gmail 앱 비밀번호 사용)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=WorkReview <noreply@workreview.com>

# Google OAuth (운영용 클라이언트 ID/Secret)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend.railway.app/api/auth/google/callback

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key
