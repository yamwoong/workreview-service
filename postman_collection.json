{
  "info": {
    "name": "WorkReview API - Test Collection",
    "description": "백엔드 수정 사항 테스트용 컬렉션\n\n테스트 순서:\n1. Auth API (verifiedReviewCount 제거 확인)\n2. Store API (verifiedCount 제거 확인)\n3. Review API (wageType 필드 테스트)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "accessToken2",
      "value": "",
      "type": "string"
    },
    {
      "key": "accessToken3",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "reviewId1",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth API - verifiedReviewCount 제거 확인",
      "item": [
        {
          "name": "1-1. 회원가입 (User 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// accessToken 자동 저장",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', response.data.accessToken);",
                  "    ",
                  "    // verifiedReviewCount 없는지 확인",
                  "    pm.test('❌ verifiedReviewCount 필드가 없어야 함', function() {",
                  "        pm.expect(response.data.user).to.not.have.property('verifiedReviewCount');",
                  "    });",
                  "    ",
                  "    // Gamification 필드 있는지 확인",
                  "    pm.test('✅ points 필드 있음', function() {",
                  "        pm.expect(response.data.user).to.have.property('points');",
                  "    });",
                  "    pm.test('✅ trustScore 필드 있음', function() {",
                  "        pm.expect(response.data.user).to.have.property('trustScore');",
                  "    });",
                  "    pm.test('✅ reviewCount 필드 있음', function() {",
                  "        pm.expect(response.data.user).to.have.property('reviewCount');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test1@example.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"Test User 1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "1-2. 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.test('❌ verifiedReviewCount 필드가 없어야 함', function() {",
                  "        pm.expect(response.data.user).to.not.have.property('verifiedReviewCount');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test1@example.com\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "1-3. 내 정보 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.test('❌ verifiedReviewCount 필드가 없어야 함', function() {",
                  "        pm.expect(response.data).to.not.have.property('verifiedReviewCount');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Store API - verifiedCount 제거 확인",
      "item": [
        {
          "name": "2-1. 가게 등록",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('storeId', response.data._id);",
                  "    ",
                  "    pm.test('❌ verifiedCount 필드가 없어야 함', function() {",
                  "        pm.expect(response.data).to.not.have.property('verifiedCount');",
                  "    });",
                  "    ",
                  "    pm.test('✅ reviewCount 필드 있음', function() {",
                  "        pm.expect(response.data).to.have.property('reviewCount');",
                  "        pm.expect(response.data.reviewCount).to.equal(0);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"googlePlaceId\": \"test_place_123\",\n  \"name\": \"Test Starbucks\",\n  \"address\": \"123 Oxford St, London W1D 2DW, UK\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [-0.1319, 51.5155]\n  },\n  \"category\": \"cafe\",\n  \"phone\": \"+44 20 1234 5678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stores",
              "host": ["{{baseUrl}}"],
              "path": ["stores"]
            }
          },
          "response": []
        },
        {
          "name": "2-2. 가게 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.test('❌ verifiedCount 필드가 없어야 함', function() {",
                  "        pm.expect(response.data).to.not.have.property('verifiedCount');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stores/{{storeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["stores", "{{storeId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Review API - wageType 필드 테스트",
      "item": [
        {
          "name": "3-1. 리뷰 작성 - wageType: custom",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('reviewId1', response.data._id);",
                  "    ",
                  "    pm.test('✅ wageType이 custom이어야 함', function() {",
                  "        pm.expect(response.data.wageType).to.equal('custom');",
                  "    });",
                  "    ",
                  "    pm.test('✅ hourlyWage가 12.50이어야 함', function() {",
                  "        pm.expect(response.data.hourlyWage).to.equal(12.50);",
                  "    });",
                  "    ",
                  "    pm.test('❌ payslipUrl 필드가 없어야 함', function() {",
                  "        pm.expect(response.data).to.not.have.property('payslipUrl');",
                  "    });",
                  "    ",
                  "    pm.test('❌ isPayslipVerified 필드가 없어야 함', function() {",
                  "        pm.expect(response.data).to.not.have.property('isPayslipVerified');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store\": \"{{storeId}}\",\n  \"reviewMode\": \"detailed\",\n  \"ratings\": {\n    \"salary\": 5,\n    \"restTime\": 4,\n    \"workEnv\": 4,\n    \"management\": 5\n  },\n  \"wageType\": \"custom\",\n  \"hourlyWage\": 12.50,\n  \"content\": \"Great place to work! Testing wageType custom with exact hourly wage.\",\n  \"position\": \"Barista\",\n  \"pros\": \"Good pay, nice team\",\n  \"cons\": \"Can be busy during rush hours\",\n  \"workPeriod\": {\n    \"start\": \"2024-06-01\",\n    \"end\": \"2024-11-30\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["reviews"]
            }
          },
          "response": []
        },
        {
          "name": "3-2. 회원가입 (User 2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken2', response.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test2@example.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"Test User 2\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "3-3. 리뷰 작성 - wageType: minimum_wage",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.test('✅ wageType이 minimum_wage여야 함', function() {",
                  "        pm.expect(response.data.wageType).to.equal('minimum_wage');",
                  "    });",
                  "    ",
                  "    pm.test('✅ hourlyWage가 null이거나 없어야 함', function() {",
                  "        const hasHourlyWage = response.data.hasOwnProperty('hourlyWage');",
                  "        if (hasHourlyWage) {",
                  "            pm.expect(response.data.hourlyWage).to.be.null;",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken2}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store\": \"{{storeId}}\",\n  \"reviewMode\": \"quick\",\n  \"ratings\": {\n    \"salary\": 3,\n    \"restTime\": 3,\n    \"workEnv\": 3,\n    \"management\": 3\n  },\n  \"wageType\": \"minimum_wage\",\n  \"content\": \"Minimum wage job, decent experience.\",\n  \"position\": \"Server\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["reviews"]
            }
          },
          "response": []
        },
        {
          "name": "3-4. 회원가입 (User 3)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken3', response.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test3@example.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"Test User 3\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "3-5. 리뷰 작성 - wageType 없이",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ 리뷰 생성 성공 (wageType 없어도 됨)', function() {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken3}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store\": \"{{storeId}}\",\n  \"reviewMode\": \"quick\",\n  \"ratings\": {\n    \"salary\": 4,\n    \"restTime\": 4,\n    \"workEnv\": 4,\n    \"management\": 4\n  },\n  \"content\": \"Good workplace, not sharing wage info.\",\n  \"position\": \"Team Member\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["reviews"]
            }
          },
          "response": []
        },
        {
          "name": "3-6. 리뷰 목록 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.test('✅ 3개 리뷰 있어야 함', function() {",
                  "        pm.expect(response.data.reviews).to.have.lengthOf(3);",
                  "    });",
                  "    ",
                  "    pm.test('❌ payslipUrl 필드가 없어야 함', function() {",
                  "        response.data.reviews.forEach(review => {",
                  "            pm.expect(review).to.not.have.property('payslipUrl');",
                  "        });",
                  "    });",
                  "    ",
                  "    pm.test('❌ isPayslipVerified 필드가 없어야 함', function() {",
                  "        response.data.reviews.forEach(review => {",
                  "            pm.expect(review).to.not.have.property('isPayslipVerified');",
                  "        });",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stores/{{storeId}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["stores", "{{storeId}}", "reviews"]
            }
          },
          "response": []
        },
        {
          "name": "3-7. 리뷰 필터링 - wageType",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    pm.test('✅ minimum_wage 리뷰만 조회되어야 함', function() {",
                  "        response.data.reviews.forEach(review => {",
                  "            pm.expect(review.wageType).to.equal('minimum_wage');",
                  "        });",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reviews?wageType=minimum_wage",
              "host": ["{{baseUrl}}"],
              "path": ["reviews"],
              "query": [
                {
                  "key": "wageType",
                  "value": "minimum_wage"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
