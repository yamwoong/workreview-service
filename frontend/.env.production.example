# =============================================
# 운영 환경 변수 템플릿 (Vercel에 직접 입력)
# =============================================
# 이 파일은 참고용 템플릿입니다.
# 실제 값은 Vercel 대시보드 > Settings > Environment Variables에서 설정하세요.

# API URL (Railway 백엔드 배포 후 주소 입력)
VITE_API_URL=https://your-backend.railway.app/api

# Environment
VITE_ENV=production

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
